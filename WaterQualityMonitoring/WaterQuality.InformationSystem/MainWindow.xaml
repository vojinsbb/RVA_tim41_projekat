<Window x:Class="WaterQuality.InformationSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Water Quality Information System"
        Height="750"
        Width="1200"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="220"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Water Source Management"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <Border Grid.Row="1"
                BorderBrush="Gray"
                BorderThickness="1"
                Padding="10"
                Margin="0,0,0,15">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="50"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="Name:"
                           VerticalAlignment="Center"/>

                <TextBox Grid.Row="0"
                         Grid.Column="1"
                         Text="{Binding SourceName, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,5,20,5"/>

                <TextBlock Grid.Row="0"
                           Grid.Column="2"
                           Text="Location:"
                           VerticalAlignment="Center"/>

                <TextBox Grid.Row="0"
                         Grid.Column="3"
                         Text="{Binding SourceLocation, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,5,20,5"/>

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Text="Source type:"
                           VerticalAlignment="Center"/>

                <TextBox Grid.Row="1"
                         Grid.Column="1"
                         Text="{Binding SourceType, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,5,20,5"/>

                <TextBlock Grid.Row="1"
                           Grid.Column="2"
                           Text="Municipality:"
                           VerticalAlignment="Center"/>

                <TextBox Grid.Row="1"
                         Grid.Column="3"
                         Text="{Binding SourceMunicipality, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,5,20,5"/>

                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Text="Capacity m3:"
                           VerticalAlignment="Center"/>

                <TextBox Grid.Row="2"
                         Grid.Column="1"
                         Text="{Binding SourceCapacityM3, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,5,20,5"/>

                <StackPanel Grid.Row="3"
                            Grid.Column="0"
                            Grid.ColumnSpan="4"
                            Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            Margin="0,10,0,0">

                    <Button Content="Add"
                            Width="100"
                            Height="30"
                            Margin="0,0,10,0"
                            Command="{Binding AddWaterSourceCommand}"/>

                    <Button Content="Update"
                            Width="100"
                            Height="30"
                            Margin="0,0,10,0"
                            Command="{Binding UpdateWaterSourceCommand}"/>

                    <Button Content="Delete"
                            Width="100"
                            Height="30"
                            Margin="0,0,10,0"
                            Command="{Binding DeleteWaterSourceCommand}"/>

                    <Button Content="Clear"
                            Width="100"
                            Height="30"
                            Command="{Binding ClearWaterSourceFormCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <TextBlock Grid.Row="2"
                   Text="Water Sources"
                   FontSize="20"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding WaterSources}"
                  SelectedItem="{Binding SelectedWaterSource, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  Margin="0,0,0,20">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Id"
                                    Binding="{Binding Id}"
                                    Width="220"/>

                <DataGridTextColumn Header="Name"
                                    Binding="{Binding Name}"
                                    Width="*"/>

                <DataGridTextColumn Header="Location"
                                    Binding="{Binding Location}"
                                    Width="*"/>

                <DataGridTextColumn Header="Source Type"
                                    Binding="{Binding SourceType}"
                                    Width="*"/>

                <DataGridTextColumn Header="Municipality"
                                    Binding="{Binding Municipality}"
                                    Width="*"/>

                <DataGridTextColumn Header="Capacity m3"
                                    Binding="{Binding CapacityM3}"
                                    Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="4"
                   Text="Water Quality Readings"
                   FontSize="20"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <DataGrid Grid.Row="5"
                  ItemsSource="{Binding WaterQualityReadings}"
                  AutoGenerateColumns="True"
                  IsReadOnly="True"/>
    </Grid>
</Window>