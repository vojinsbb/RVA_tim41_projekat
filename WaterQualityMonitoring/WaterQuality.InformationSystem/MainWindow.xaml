<Window x:Class="WaterQuality.InformationSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Water Quality Information System"
        Height="850"
        Width="1300"
        WindowStartupLocation="CenterScreen">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="220"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="220"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="220"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="220"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                    Text="Water Source Management"
                    FontSize="22"
                    FontWeight="Bold"
                    VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                    Content="Undo"
                    Width="100"
                    Height="30"
                    Margin="0,0,10,0"
                    Command="{Binding UndoCommand}"/>

                <Button Grid.Column="2"
                    Content="Redo"
                    Width="100"
                    Height="30"
                    Margin="0,0,10,0"
                    Command="{Binding RedoCommand}"/>

                <Button Grid.Column="3"
                    Content="Save Data"
                    Width="100"
                    Height="30"
                    Margin="0,0,10,0"
                    Command="{Binding SaveDataCommand}"/>

                <Button Grid.Column="4"
                    Content="Load Data"
                    Width="100"
                    Height="30"
                    Command="{Binding LoadDataCommand}"/>
            </Grid>

            <Border Grid.Row="1"
                BorderBrush="Gray"
                BorderThickness="1"
                Padding="10"
                Margin="0,0,0,15">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="50"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Text="Name:"
                               VerticalAlignment="Center"/>

                    <TextBox Grid.Row="0"
                             Grid.Column="1"
                             Text="{Binding SourceName, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,5,20,5"/>

                    <TextBlock Grid.Row="0"
                               Grid.Column="2"
                               Text="Location:"
                               VerticalAlignment="Center"/>

                    <TextBox Grid.Row="0"
                             Grid.Column="3"
                             Text="{Binding SourceLocation, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,5,20,5"/>

                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               Text="Source type:"
                               VerticalAlignment="Center"/>

                    <TextBox Grid.Row="1"
                             Grid.Column="1"
                             Text="{Binding SourceType, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,5,20,5"/>

                    <TextBlock Grid.Row="1"
                               Grid.Column="2"
                               Text="Municipality:"
                               VerticalAlignment="Center"/>

                    <TextBox Grid.Row="1"
                             Grid.Column="3"
                             Text="{Binding SourceMunicipality, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,5,20,5"/>

                    <TextBlock Grid.Row="2"
                               Grid.Column="0"
                               Text="Capacity m3:"
                               VerticalAlignment="Center"/>

                    <TextBox Grid.Row="2"
                             Grid.Column="1"
                             Text="{Binding SourceCapacityM3, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,5,20,5"/>

                    <StackPanel Grid.Row="3"
                                Grid.Column="0"
                                Grid.ColumnSpan="4"
                                Orientation="Horizontal"
                                HorizontalAlignment="Left"
                                Margin="0,10,0,0">

                        <Button Content="Add"
                                Width="100"
                                Height="30"
                                Margin="0,0,10,0"
                                Command="{Binding AddWaterSourceCommand}"/>

                        <Button Content="Update"
                                Width="100"
                                Height="30"
                                Margin="0,0,10,0"
                                Command="{Binding UpdateWaterSourceCommand}"/>

                        <Button Content="Delete"
                                Width="100"
                                Height="30"
                                Margin="0,0,10,0"
                                Command="{Binding DeleteWaterSourceCommand}"/>

                        <Button Content="Clear"
                                Width="100"
                                Height="30"
                                Command="{Binding ClearWaterSourceFormCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="2" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                    Text="Water Sources"
                    FontSize="20"
                    FontWeight="Bold"
                    VerticalAlignment="Center"
                    Margin="0,0,20,0"/>
                
                <TextBox Grid.Column="1"
                     Text="{Binding SourceSearchText, UpdateSourceTrigger=PropertyChanged}"
                    Height="28"
                    Margin="0,0,10,0"/>

                <Button Grid.Column="2"
                    Content="Search"
                    Width="90"
                    Height="28"
                    Margin="0,0,10,0"
                    Command="{Binding SearchWaterSourcesCommand}"/>

                <Button Grid.Column="3"
                    Content="Reset"
                    Width="90"
                    Height="28"
                    Command="{Binding ResetWaterSourcesSearchCommand}"/>
            </Grid>

            <DataGrid Grid.Row="3"
                      ItemsSource="{Binding WaterSources}"
                      SelectedItem="{Binding SelectedWaterSource, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      Margin="0,0,0,20">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Id"
                                        Binding="{Binding Id}"
                                        Width="220"/>

                    <DataGridTextColumn Header="Name"
                                        Binding="{Binding Name}"
                                        Width="*"/>

                    <DataGridTextColumn Header="Location"
                                        Binding="{Binding Location}"
                                        Width="*"/>

                    <DataGridTextColumn Header="Source Type"
                                        Binding="{Binding SourceType}"
                                        Width="*"/>

                    <DataGridTextColumn Header="Municipality"
                                        Binding="{Binding Municipality}"
                                        Width="*"/>

                    <DataGridTextColumn Header="Capacity m3"
                                        Binding="{Binding CapacityM3, StringFormat={}{0:F2}}"
                                        Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

            <TextBlock Grid.Row="4"
                       Text="Water Quality Reading Management"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

            <Border Grid.Row="5"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    Padding="10"
                    Margin="0,0,0,15">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="280"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="50"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Text="Water source:"
                               VerticalAlignment="Center"/>

                    <ComboBox Grid.Row="0"
                              Grid.Column="1"
                              ItemsSource="{Binding WaterSources}"
                              SelectedItem="{Binding SelectedReadingSource, Mode=TwoWay}"
                              DisplayMemberPath="Name"
                              Margin="0,5,20,5"/>

                    <TextBlock Grid.Row="0"
                               Grid.Column="2"
                               Text="Sampled at:"
                               VerticalAlignment="Center"/>

                    <DatePicker Grid.Row="0"
                                Grid.Column="3"
                                SelectedDate="{Binding ReadingSampledAt, Mode=TwoWay}"
                                Margin="0,5,20,5"/>

                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               Text="pH level:"
                               VerticalAlignment="Center"/>

                    <TextBox Grid.Row="1"
                             Grid.Column="1"
                             Text="{Binding ReadingPHLevel, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,5,20,5"/>

                    <TextBlock Grid.Row="1"
                               Grid.Column="2"
                               Text="Turbidity NTU:"
                               VerticalAlignment="Center"/>

                    <TextBox Grid.Row="1"
                             Grid.Column="3"
                             Text="{Binding ReadingTurbidityNTU, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,5,20,5"/>

                    <TextBlock Grid.Row="2"
                               Grid.Column="0"
                               Text="Chlorine level:"
                               VerticalAlignment="Center"/>

                    <TextBox Grid.Row="2"
                             Grid.Column="1"
                             Text="{Binding ReadingChlorineLevel, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,5,20,5"/>

                    <TextBlock Grid.Row="2"
                               Grid.Column="2"
                               Text="State:"
                               VerticalAlignment="Center"/>

                    <ComboBox Grid.Row="2"
                              Grid.Column="3"
                              ItemsSource="{Binding WaterStates}"
                              SelectedItem="{Binding SelectedReadingState, Mode=TwoWay}"
                              Margin="0,5,20,5"/>

                    <StackPanel Grid.Row="3"
                                Grid.Column="0"
                                Grid.ColumnSpan="4"
                                Orientation="Horizontal"
                                HorizontalAlignment="Left"
                                Margin="0,10,0,0">

                        <Button Content="Add"
                                Width="100"
                                Height="30"
                                Margin="0,0,10,0"
                                Command="{Binding AddWaterQualityReadingCommand}"/>

                        <Button Content="Update"
                                Width="100"
                                Height="30"
                                Margin="0,0,10,0"
                                Command="{Binding UpdateWaterQualityReadingCommand}"/>

                        <Button Content="Delete"
                                Width="100"
                                Height="30"
                                Margin="0,0,10,0"
                                Command="{Binding DeleteWaterQualityReadingCommand}"/>

                        <Button Content="Clear"
                                Width="100"
                                Height="30"
                                Command="{Binding ClearWaterQualityReadingFormCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="6" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                    Text="Water Quality Readings"
                    FontSize="20"
                    FontWeight="Bold"
                    VerticalAlignment="Center"
                    Margin="0,0,20,0"/>

                <TextBox Grid.Column="1"
                    Text="{Binding ReadingSearchText, UpdateSourceTrigger=PropertyChanged}"
                    Height="28"
                    Margin="0,0,10,0"/>

                <Button Grid.Column="2"
                    Content="Search"
                    Width="90"
                    Height="28"
                    Margin="0,0,10,0"
                    Command="{Binding SearchWaterQualityReadingsCommand}"/>

                <Button Grid.Column="3"
                    Content="Reset"
                    Width="90"
                    Height="28"
                    Command="{Binding ResetWaterQualityReadingsSearchCommand}"/>
            </Grid>

            <DataGrid Grid.Row="7"
                      ItemsSource="{Binding WaterQualityReadings}"
                      SelectedItem="{Binding SelectedWaterQualityReading, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Id"
                                        Binding="{Binding Id}"
                                        Width="220"/>

                    <DataGridTextColumn Header="Source Id"
                                        Binding="{Binding SourceId}"
                                        Width="220"/>

                    <DataGridTextColumn Header="Sampled At"
                                        Binding="{Binding SampledAt}"
                                        Width="*"/>

                    <DataGridTextColumn Header="pH"
                                        Binding="{Binding PHLevel, StringFormat={}{0:F2}}"
                                        Width="*"/>

                    <DataGridTextColumn Header="Turbidity NTU"
                                        Binding="{Binding TurbidityNTU, StringFormat={}{0:F2}}"
                                        Width="*"/>

                    <DataGridTextColumn Header="Chlorine"
                                        Binding="{Binding ChlorineLevel, StringFormat={}{0:F2}}"
                                        Width="*"/>

                    <DataGridTextColumn Header="State"
                                        Binding="{Binding State}"
                                        Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </ScrollViewer>
</Window>