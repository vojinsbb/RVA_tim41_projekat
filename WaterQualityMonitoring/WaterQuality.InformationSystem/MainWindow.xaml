<Window x:Class="WaterQuality.InformationSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        Title="Water Quality Information System"
        Height="900"
        Width="1400"
        MinHeight="800"
        MinWidth="1200"
        WindowStartupLocation="CenterScreen"
        Background="#071A2A"
        FontFamily="Segoe UI">

    <Window.Resources>

        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#071A2A"/>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#0F2A3D"/>
        <SolidColorBrush x:Key="CardBackgroundLightBrush" Color="#12344A"/>
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F4FAFF"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#A8C3D8"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#22D3EE"/>
        <SolidColorBrush x:Key="AccentDarkBrush" Color="#0891B2"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#22C55E"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#EF4444"/>
        <SolidColorBrush x:Key="BorderBrushModern" Color="#21495F"/>
        <SolidColorBrush x:Key="InputBackgroundBrush" Color="#081F30"/>

        <Style x:Key="PageTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="30"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        </Style>

        <Style x:Key="PageSubtitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushModern}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0,0,0,18"/>
        </Style>

        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="{StaticResource AccentDarkBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#14B8D4"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#67E8F9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#0E7490"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="#1E3A52"/>
            <Setter Property="BorderBrush" Value="#3B647C"/>
        </Style>

        <Style x:Key="SuccessButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="#15803D"/>
            <Setter Property="BorderBrush" Value="#4ADE80"/>
        </Style>

        <Style x:Key="WarningButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="#B45309"/>
            <Setter Property="BorderBrush" Value="#FBBF24"/>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="#B91C1C"/>
            <Setter Property="BorderBrush" Value="#F87171"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushModern}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="#0B2538"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="Stretch"
                                              TextElement.Foreground="{StaticResource PrimaryTextBrush}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#155E75"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#0891B2"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushModern}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          ClickMode="Press"
                                          Foreground="{StaticResource PrimaryTextBrush}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="ComboBorder"
                                                Background="{StaticResource InputBackgroundBrush}"
                                                BorderBrush="{StaticResource BorderBrushModern}"
                                                BorderThickness="1"
                                                CornerRadius="10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="38"/>
                                                </Grid.ColumnDefinitions>

                                                <ContentPresenter Grid.Column="0"
                                                                  Margin="12,0,6,0"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentStringFormat="{Binding SelectionBoxItemStringFormat, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Left"
                                                                  TextElement.Foreground="{StaticResource PrimaryTextBrush}"/>

                                                <TextBlock Grid.Column="1"
                                                           Text="⌄"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           FontSize="20"
                                                           FontWeight="Bold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Margin="0,-3,0,0"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                <Setter TargetName="ComboBorder" Property="Background" Value="#0B2538"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="ComboBorder" Property="Background" Value="#12344A"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PopupAnimation="Slide">
                                <Border Background="#0B2538"
                                        BorderBrush="{StaticResource AccentDarkBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="4"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer MaxHeight="220">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type primitives:DatePickerTextBox}">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type primitives:DatePickerTextBox}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CalendarDayButton">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="#0B2538"/>
            <Setter Property="BorderBrush" Value="#21495F"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="MinWidth" Value="28"/>
            <Setter Property="MinHeight" Value="24"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CalendarDayButton">
                        <Border x:Name="DayBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Margin="1">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{StaticResource PrimaryTextBrush}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="DayBorder" Property="Background" Value="#155E75"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="DayBorder" Property="Background" Value="{StaticResource AccentDarkBrush}"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsInactive" Value="True">
                                <Setter Property="Foreground" Value="#6F91A8"/>
                                <Setter TargetName="DayBorder" Property="Opacity" Value="0.55"/>
                            </Trigger>
                            <Trigger Property="IsToday" Value="True">
                                <Setter TargetName="DayBorder" Property="BorderThickness" Value="1"/>
                                <Setter TargetName="DayBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CalendarButton">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="#0B2538"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="MinWidth" Value="42"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CalendarButton">
                        <Border x:Name="CalendarButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Margin="1">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{StaticResource PrimaryTextBrush}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CalendarButtonBorder" Property="Background" Value="#155E75"/>
                            </Trigger>
                            <Trigger Property="IsInactive" Value="True">
                                <Setter TargetName="CalendarButtonBorder" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Calendar">
            <Setter Property="Background" Value="#0B2538"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentDarkBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushModern}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="38"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.ColumnSpan="2"
                                    x:Name="DateBorder"
                                    Background="{StaticResource InputBackgroundBrush}"
                                    BorderBrush="{StaticResource BorderBrushModern}"
                                    BorderThickness="1"
                                    CornerRadius="10"/>

                            <primitives:DatePickerTextBox x:Name="PART_TextBox"
                                                           Grid.Column="0"
                                                           VerticalContentAlignment="Center"
                                                           Background="Transparent"
                                                           Foreground="{StaticResource PrimaryTextBrush}"
                                                           BorderThickness="0"
                                                           Padding="12,0"/>

                            <Button x:Name="PART_Button"
                                    Grid.Column="1"
                                    Focusable="False"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="{StaticResource PrimaryTextBrush}"
                                    Cursor="Hand"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center">
                                <TextBlock Text="📅"
                                           Foreground="{StaticResource PrimaryTextBrush}"
                                           FontSize="14"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Button>

                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   PopupAnimation="Slide">
                                <Border Background="#0B2538"
                                        BorderBrush="{StaticResource AccentBrush}"
                                        BorderThickness="2"
                                        CornerRadius="10"
                                        Padding="8">
                                    <Calendar x:Name="PART_Calendar"
                                              Background="#0B2538"
                                              Foreground="{StaticResource PrimaryTextBrush}"
                                              BorderBrush="Transparent"/>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="DateBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="DateBorder" Property="Background" Value="#0B2538"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource CardBackgroundLightBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushModern}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="#0B2538"/>
            <Setter Property="AlternatingRowBackground" Value="#0F3045"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="RowHeight" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="HorizontalGridLinesBrush" Value="Transparent"/>
            <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#123C54"/>
            <Setter Property="Foreground" Value="#E6F7FF"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="12,0,12,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#21495F"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#155E75"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GridTextBlockStyle" TargetType="TextBlock">
            <Setter Property="Padding" Value="12,0,12,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="TextAlignment" Value="Left"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        </Style>

        <Style x:Key="ChartLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

    </Window.Resources>

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#0B2538"
                BorderBrush="#155E75"
                BorderThickness="0,0,0,1"
                Padding="24,18"
                Panel.ZIndex="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Water Quality Monitoring"
                               Style="{StaticResource PageTitleStyle}"/>
                    <TextBlock Text="Information system for water sources, quality readings, state simulation and WCF data sharing"
                               Style="{StaticResource PageSubtitleStyle}"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Undo"
                        Width="100"
                        Margin="0,0,10,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding UndoCommand}"/>

                <Button Grid.Column="2"
                        Content="Redo"
                        Width="100"
                        Margin="0,0,10,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding RedoCommand}"/>

                <Button Grid.Column="3"
                        Content="Save Data"
                        Width="110"
                        Margin="0,0,10,0"
                        Style="{StaticResource ModernButtonStyle}"
                        Command="{Binding SaveDataCommand}"/>

                <Button Grid.Column="4"
                        Content="Load Data"
                        Width="110"
                        Style="{StaticResource ModernButtonStyle}"
                        Command="{Binding LoadDataCommand}"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Background="{StaticResource PageBackgroundBrush}">
            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="260"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="260"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="270"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="18"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Water Source Management"
                                   Style="{StaticResource SectionTitleStyle}"/>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="260"/>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="260"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="42"/>
                                <RowDefinition Height="42"/>
                                <RowDefinition Height="42"/>
                                <RowDefinition Height="48"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" Style="{StaticResource LabelStyle}"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding SourceName, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Grid.Row="0" Grid.Column="3" Text="Location" Style="{StaticResource LabelStyle}"/>
                            <TextBox Grid.Row="0" Grid.Column="4" Text="{Binding SourceLocation, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Source type" Style="{StaticResource LabelStyle}"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding SourceType, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Grid.Row="1" Grid.Column="3" Text="Municipality" Style="{StaticResource LabelStyle}"/>
                            <TextBox Grid.Row="1" Grid.Column="4" Text="{Binding SourceMunicipality, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Capacity m³" Style="{StaticResource LabelStyle}"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding SourceCapacityM3, UpdateSourceTrigger=PropertyChanged}"/>

                            <StackPanel Grid.Row="3"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="5"
                                        Orientation="Horizontal"
                                        Margin="0,12,0,0">
                                <Button Content="Add" Width="100" Margin="0,0,10,0" Style="{StaticResource SuccessButtonStyle}" Command="{Binding AddWaterSourceCommand}"/>
                                <Button Content="Update" Width="100" Margin="0,0,10,0" Style="{StaticResource WarningButtonStyle}" Command="{Binding UpdateWaterSourceCommand}"/>
                                <Button Content="Delete" Width="100" Margin="0,0,10,0" Style="{StaticResource DangerButtonStyle}" Command="{Binding DeleteWaterSourceCommand}"/>
                                <Button Content="Clear" Width="100" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding ClearWaterSourceFormCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Background="#0B2538"
                        BorderBrush="#21495F"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="16"
                        Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="320"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Water Sources"
                                   Style="{StaticResource SectionTitleStyle}"
                                   Margin="0,0,22,0"/>

                        <TextBox Grid.Column="1"
                                 Text="{Binding SourceSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Height="34"
                                 Margin="0,0,10,0"/>

                        <Button Grid.Column="2"
                                Content="Search"
                                Width="95"
                                Margin="0,0,10,0"
                                Style="{StaticResource ModernButtonStyle}"
                                Command="{Binding SearchWaterSourcesCommand}"/>

                        <Button Grid.Column="3"
                                Content="Reset"
                                Width="95"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding ResetWaterSourcesSearchCommand}"/>
                    </Grid>
                </Border>

                <DataGrid Grid.Row="2"
                          ItemsSource="{Binding WaterSources}"
                          SelectedItem="{Binding SelectedWaterSource, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          AlternationCount="2"
                          Margin="0,0,0,22">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="220" ElementStyle="{StaticResource GridTextBlockStyle}"/>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" ElementStyle="{StaticResource GridTextBlockStyle}"/>
                        <DataGridTextColumn Header="Location" Binding="{Binding Location}" Width="*" ElementStyle="{StaticResource GridTextBlockStyle}"/>
                        <DataGridTextColumn Header="Source Type" Binding="{Binding SourceType}" Width="*" ElementStyle="{StaticResource GridTextBlockStyle}"/>
                        <DataGridTextColumn Header="Municipality" Binding="{Binding Municipality}" Width="*" ElementStyle="{StaticResource GridTextBlockStyle}"/>
                        <DataGridTextColumn Header="Capacity m³" Binding="{Binding CapacityM3, StringFormat={}{0:F2}}" Width="*" ElementStyle="{StaticResource GridTextBlockStyle}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Border Grid.Row="3" Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="18"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Water Quality Reading Management"
                                   Style="{StaticResource SectionTitleStyle}"/>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="270"/>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="250"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="42"/>
                                <RowDefinition Height="42"/>
                                <RowDefinition Height="42"/>
                                <RowDefinition Height="48"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Water source" Style="{StaticResource LabelStyle}"/>

                            <ComboBox Grid.Row="0"
                                      Grid.Column="1"
                                      ItemsSource="{Binding WaterSources}"
                                      SelectedItem="{Binding SelectedReadingSource, Mode=TwoWay}"
                                      DisplayMemberPath="Name"/>

                            <TextBlock Grid.Row="0" Grid.Column="3" Text="Sampled at" Style="{StaticResource LabelStyle}"/>

                            <DatePicker Grid.Row="0"
                                        Grid.Column="4"
                                        SelectedDate="{Binding ReadingSampledAt, Mode=TwoWay}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="pH level" Style="{StaticResource LabelStyle}"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ReadingPHLevel, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Grid.Row="1" Grid.Column="3" Text="Turbidity NTU" Style="{StaticResource LabelStyle}"/>
                            <TextBox Grid.Row="1" Grid.Column="4" Text="{Binding ReadingTurbidityNTU, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Chlorine level" Style="{StaticResource LabelStyle}"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding ReadingChlorineLevel, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Grid.Row="2" Grid.Column="3" Text="State" Style="{StaticResource LabelStyle}"/>

                            <ComboBox Grid.Row="2"
                                      Grid.Column="4"
                                      ItemsSource="{Binding WaterStates}"
                                      SelectedItem="{Binding SelectedReadingState, Mode=TwoWay}"/>

                            <StackPanel Grid.Row="3"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="6"
                                        Orientation="Horizontal"
                                        Margin="0,12,0,0">
                                <Button Content="Add" Width="100" Margin="0,0,10,0" Style="{StaticResource SuccessButtonStyle}" Command="{Binding AddWaterQualityReadingCommand}"/>
                                <Button Content="Update" Width="100" Margin="0,0,10,0" Style="{StaticResource WarningButtonStyle}" Command="{Binding UpdateWaterQualityReadingCommand}"/>
                                <Button Content="Delete" Width="100" Margin="0,0,10,0" Style="{StaticResource DangerButtonStyle}" Command="{Binding DeleteWaterQualityReadingCommand}"/>
                                <Button Content="Clear" Width="100" Margin="0,0,10,0" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding ClearWaterQualityReadingFormCommand}"/>
                                <Button Content="Simulate States" Width="145" Style="{StaticResource ModernButtonStyle}" Command="{Binding SimulateReadingStatesCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="4"
                        Background="#0B2538"
                        BorderBrush="#21495F"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="16"
                        Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="320"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Water Quality Readings"
                                   Style="{StaticResource SectionTitleStyle}"
                                   Margin="0,0,22,0"/>

                        <TextBox Grid.Column="1"
                                 Text="{Binding ReadingSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Height="34"
                                 Margin="0,0,10,0"/>

                        <Button Grid.Column="2"
                                Content="Search"
                                Width="95"
                                Margin="0,0,10,0"
                                Style="{StaticResource ModernButtonStyle}"
                                Command="{Binding SearchWaterQualityReadingsCommand}"/>

                        <Button Grid.Column="3"
                                Content="Reset"
                                Width="95"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding ResetWaterQualityReadingsSearchCommand}"/>
                    </Grid>
                </Border>

                <DataGrid Grid.Row="5"
                          ItemsSource="{Binding WaterQualityReadings}"
                          SelectedItem="{Binding SelectedWaterQualityReading, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          AlternationCount="2"
                          Margin="0,0,0,22">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="220" ElementStyle="{StaticResource GridTextBlockStyle}"/>
                        <DataGridTextColumn Header="Source Id" Binding="{Binding SourceId}" Width="220" ElementStyle="{StaticResource GridTextBlockStyle}"/>
                        <DataGridTextColumn Header="Sampled At" Binding="{Binding SampledAt}" Width="*" ElementStyle="{StaticResource GridTextBlockStyle}"/>
                        <DataGridTextColumn Header="pH" Binding="{Binding PHLevel, StringFormat={}{0:F2}}" Width="*" ElementStyle="{StaticResource GridTextBlockStyle}"/>
                        <DataGridTextColumn Header="Turbidity NTU" Binding="{Binding TurbidityNTU, StringFormat={}{0:F2}}" Width="*" ElementStyle="{StaticResource GridTextBlockStyle}"/>
                        <DataGridTextColumn Header="Chlorine" Binding="{Binding ChlorineLevel, StringFormat={}{0:F2}}" Width="*" ElementStyle="{StaticResource GridTextBlockStyle}"/>
                        <DataGridTextColumn Header="State" Binding="{Binding State}" Width="*" ElementStyle="{StaticResource GridTextBlockStyle}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Border Grid.Row="6"
                        Background="#0B2538"
                        BorderBrush="#21495F"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="16"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Water Quality State Chart"
                                   Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock Text="Real-time overview of readings grouped by current water quality state"
                                   Style="{StaticResource PageSubtitleStyle}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="7"
                        Background="{StaticResource CardBackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrushModern}"
                        BorderThickness="1"
                        CornerRadius="18"
                        Padding="20"
                        Margin="0,0,0,20">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="45"/>
                            <RowDefinition Height="45"/>
                            <RowDefinition Height="45"/>
                            <RowDefinition Height="45"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="{Binding StateChartSummary}"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}"
                                   Margin="0,0,0,16"/>

                        <Grid Grid.Row="1" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Safe" Style="{StaticResource ChartLabelStyle}"/>

                            <ProgressBar Grid.Column="1"
                                         Minimum="0"
                                         Maximum="{Binding MaxStateCount}"
                                         Value="{Binding SafeCount}"
                                         Foreground="{StaticResource SuccessBrush}"
                                         Background="#082333"
                                         BorderBrush="#21495F"
                                         Height="26"
                                         VerticalAlignment="Center"/>

                            <TextBlock Grid.Column="2" Text="{Binding SafeCount}" Style="{StaticResource ChartLabelStyle}" HorizontalAlignment="Center"/>
                        </Grid>

                        <Grid Grid.Row="2" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Acceptable" Style="{StaticResource ChartLabelStyle}"/>

                            <ProgressBar Grid.Column="1"
                                         Minimum="0"
                                         Maximum="{Binding MaxStateCount}"
                                         Value="{Binding AcceptableCount}"
                                         Foreground="{StaticResource AccentBrush}"
                                         Background="#082333"
                                         BorderBrush="#21495F"
                                         Height="26"
                                         VerticalAlignment="Center"/>

                            <TextBlock Grid.Column="2" Text="{Binding AcceptableCount}" Style="{StaticResource ChartLabelStyle}" HorizontalAlignment="Center"/>
                        </Grid>

                        <Grid Grid.Row="3" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Unsafe" Style="{StaticResource ChartLabelStyle}"/>

                            <ProgressBar Grid.Column="1"
                                         Minimum="0"
                                         Maximum="{Binding MaxStateCount}"
                                         Value="{Binding UnsafeCount}"
                                         Foreground="{StaticResource WarningBrush}"
                                         Background="#082333"
                                         BorderBrush="#21495F"
                                         Height="26"
                                         VerticalAlignment="Center"/>

                            <TextBlock Grid.Column="2" Text="{Binding UnsafeCount}" Style="{StaticResource ChartLabelStyle}" HorizontalAlignment="Center"/>
                        </Grid>

                        <Grid Grid.Row="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Contaminated" Style="{StaticResource ChartLabelStyle}"/>

                            <ProgressBar Grid.Column="1"
                                         Minimum="0"
                                         Maximum="{Binding MaxStateCount}"
                                         Value="{Binding ContaminatedCount}"
                                         Foreground="{StaticResource DangerBrush}"
                                         Background="#082333"
                                         BorderBrush="#21495F"
                                         Height="26"
                                         VerticalAlignment="Center"/>

                            <TextBlock Grid.Column="2" Text="{Binding ContaminatedCount}" Style="{StaticResource ChartLabelStyle}" HorizontalAlignment="Center"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>