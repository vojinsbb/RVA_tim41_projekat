<Window x:Class="WaterQuality.StatisticsApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WaterQuality.StatisticsApp.ViewModels"
        Title="Statistička obrada kvaliteta vode"
        Height="800"
        Width="1200"
        MinHeight="700"
        MinWidth="1050"
        WindowStartupLocation="CenterScreen"
        Background="#071A2A"
        FontFamily="Segoe UI">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#071A2A"/>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#0F2A3D"/>
        <SolidColorBrush x:Key="CardBackgroundLightBrush" Color="#12344A"/>
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F4FAFF"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#A8C3D8"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#22D3EE"/>
        <SolidColorBrush x:Key="AccentDarkBrush" Color="#0891B2"/>
        <SolidColorBrush x:Key="BorderBrushModern" Color="#21495F"/>
        <SolidColorBrush x:Key="InputBackgroundBrush" Color="#081F30"/>

        <Style x:Key="PageTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="30"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        </Style>

        <Style x:Key="PageSubtitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushModern}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0,0,0,18"/>
        </Style>

        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="{StaticResource AccentDarkBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#14B8D4"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#67E8F9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#0E7490"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="#1E3A52"/>
            <Setter Property="BorderBrush" Value="#3B647C"/>
        </Style>

        <Style x:Key="SuccessButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="#15803D"/>
            <Setter Property="BorderBrush" Value="#4ADE80"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushModern}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushModern}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{StaticResource InputBackgroundBrush}"
                                        BorderBrush="{StaticResource BorderBrushModern}"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                            <ContentPresenter Margin="12,0,35,0"
                                                      VerticalAlignment="Center"
                                                      Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                      TextElement.Foreground="{StaticResource PrimaryTextBrush}"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <TextBlock Text="⌄"
                               Foreground="{StaticResource AccentBrush}"
                               FontSize="18"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"/>

                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                           Placement="Bottom"
                           AllowsTransparency="True">
                                <Border Background="#0B2538"
                                BorderBrush="{StaticResource AccentDarkBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#0B2538"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                        Background="{TemplateBinding Background}"
                        Padding="{TemplateBinding Padding}">
                            <ContentPresenter TextElement.Foreground="#FFFFFF"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#155E75"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#0891B2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushModern}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource CardBackgroundLightBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushModern}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="#0B2538"/>
            <Setter Property="AlternatingRowBackground" Value="#0F3045"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="RowHeight" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#123C54"/>
            <Setter Property="Foreground" Value="#E6F7FF"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="12,0"/>
        </Style>

        <Style x:Key="GridTextBlockStyle" TargetType="TextBlock">
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#0B2538"
                BorderBrush="#155E75"
                BorderThickness="0,0,0,1"
                Padding="24,18">
            <StackPanel>
                <TextBlock Text="Water Quality Statistics"
                           Style="{StaticResource PageTitleStyle}"/>
                <TextBlock Text="Statistical processing, WCF data retrieval, dictionary mapping and CSV export"
                           Style="{StaticResource PageSubtitleStyle}"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="360"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="18"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Data Request"
                                   Style="{StaticResource SectionTitleStyle}"/>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="260"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Source" Style="{StaticResource LabelStyle}" Margin="0,0,10,0"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding Sources}"
                                      SelectedItem="{Binding SelectedSource}"
                                      DisplayMemberPath="Name"/>

                            <TextBlock Grid.Column="3" Text="Year" Style="{StaticResource LabelStyle}" Margin="0,0,10,0"/>
                            <TextBox Grid.Column="4"
                                     Text="{Binding SelectedYear, UpdateSourceTrigger=PropertyChanged}"/>

                            <Button Grid.Column="6"
                                    Content="Load Sources"
                                    Width="130"
                                    Margin="0,0,10,0"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding LoadSourcesCommand}"/>

                            <Button Grid.Column="7"
                                    Content="Load Readings"
                                    Width="135"
                                    Style="{StaticResource ModernButtonStyle}"
                                    Command="{Binding LoadReadingsCommand}"/>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="18"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Statistical Method"
                                   Style="{StaticResource SectionTitleStyle}"/>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="300"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Method" Style="{StaticResource LabelStyle}" Margin="0,0,10,0"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding Strategies}"
                                      SelectedItem="{Binding SelectedStrategy}"
                                      DisplayMemberPath="Name"/>

                            <Button Grid.Column="3"
                                    Content="Calculate"
                                    Width="120"
                                    Margin="0,0,10,0"
                                    Style="{StaticResource ModernButtonStyle}"
                                    Command="{Binding CalculateStatisticsCommand}"/>

                            <Button Grid.Column="4"
                                    Content="Export CSV"
                                    Width="120"
                                    Style="{StaticResource SuccessButtonStyle}"
                                    Command="{Binding ExportCsvCommand}"/>

                            <TextBlock Grid.Column="6"
                                       Text="{Binding StatisticsResult}"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontWeight="Bold"
                                       FontSize="15"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Grid>
                </Border>

                <DataGrid Grid.Row="2"
                          ItemsSource="{Binding Readings}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          AlternationCount="2"
                          Margin="0,0,0,18">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="220" ElementStyle="{StaticResource GridTextBlockStyle}"/>
                        <DataGridTextColumn Header="Source Id" Binding="{Binding SourceId}" Width="220" ElementStyle="{StaticResource GridTextBlockStyle}"/>
                        <DataGridTextColumn Header="Sampled At" Binding="{Binding SampledAt}" Width="*" ElementStyle="{StaticResource GridTextBlockStyle}"/>
                        <DataGridTextColumn Header="pH" Binding="{Binding PHLevel, StringFormat={}{0:F2}}" Width="90" ElementStyle="{StaticResource GridTextBlockStyle}"/>
                        <DataGridTextColumn Header="Turbidity NTU" Binding="{Binding TurbidityNTU, StringFormat={}{0:F2}}" Width="130" ElementStyle="{StaticResource GridTextBlockStyle}"/>
                        <DataGridTextColumn Header="Chlorine" Binding="{Binding ChlorineLevel, StringFormat={}{0:F2}}" Width="110" ElementStyle="{StaticResource GridTextBlockStyle}"/>
                        <DataGridTextColumn Header="State" Binding="{Binding State}" Width="130" ElementStyle="{StaticResource GridTextBlockStyle}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Border Grid.Row="3" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Dictionary View"
                                   Style="{StaticResource SectionTitleStyle}"
                                   Margin="0,0,0,10"/>

                        <ListBox ItemsSource="{Binding DictionaryDisplay}"
                                 Height="100"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="4"
                        Background="#0B2538"
                        BorderBrush="#155E75"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="14"
                        Margin="0,0,0,20">
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               FontWeight="SemiBold"/>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>